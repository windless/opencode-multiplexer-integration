{
  "name": "opencode-multiplexer-integration",
  "version": "0.1.0",
  "description": "Terminal multiplexer (tmux/zellij) integration for OpenCode — spawn subagent sessions as live panes",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "type": "module",
  "license": "MIT",
  "keywords": [
    "opencode",
    "opencode-plugin",
    "multiplexer",
    "tmux",
    "zellij",
    "subagent",
    "terminal"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/alvinunreal/opencode-multiplexer-integration"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm --external @opencode-ai/plugin --external @opencode-ai/sdk --external zod && tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check --write .",
    "check:ci": "biome check ."
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "^1.3.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@types/node": "^24.6.1",
    "bun-types": "1.3.12",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.3.17",
    "opencode-multiplexer-integration": "/Users/libright/Documents/mine/open-source/multiplexer-integration"
  }
}
